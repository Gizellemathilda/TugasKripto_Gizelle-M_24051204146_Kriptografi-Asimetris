import tkinter as tk
from tkinter import ttk
import random
import math

def gcd(a,b):
    while b!=0:
        a,b=b,a%b
    return a

def mod_exp(base,exp,mod):
    result=1
    base%=mod
    while exp>0:
        if exp%2==1:
            result=(result*base)%mod
        exp//=2
        base=(base*base)%mod
    return result

def mod_inverse(a,m):
    for x in range(1,m):
        if (a*x)%m==1:
            return x
    return None

def is_prime(n):
    if n<2:
        return False
    for i in range(2,int(math.sqrt(n))+1):
        if n%i==0:
            return False
    return True

def generate_prime():
    while True:
        num=random.randint(100,300)
        if is_prime(num):
            return num

# RSA

def rsa_generate():

    global rsa_e,rsa_d,rsa_n

    p=generate_prime()
    q=generate_prime()

    rsa_n=p*q
    phi=(p-1)*(q-1)

    rsa_e=random.randint(2,phi-1)
    while gcd(rsa_e,phi)!=1:
        rsa_e=random.randint(2,phi-1)

    rsa_d=mod_inverse(rsa_e,phi)

    rsa_pub.config(text=f"Public Key (e,n): {rsa_e},{rsa_n}")
    rsa_priv.config(text=f"Private Key (d,n): {rsa_d},{rsa_n}")

def rsa_encrypt():

    text=rsa_plain.get()
    cipher=[]

    for c in text:
        cipher.append(str(mod_exp(ord(c),rsa_e,rsa_n)))

    rsa_cipher.delete(0,tk.END)
    rsa_cipher.insert(0," ".join(cipher))

def rsa_decrypt():

    cipher=rsa_cipher.get().split()

    text=""

    for c in cipher:
        m=mod_exp(int(c),rsa_d,rsa_n)
        text+=chr(m)

    rsa_decrypted.delete(0,tk.END)
    rsa_decrypted.insert(0,text)


# DIFFIE HELLMAN


