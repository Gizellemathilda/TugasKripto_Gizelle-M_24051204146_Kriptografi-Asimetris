    p=dh_p.get()
    g=dh_g.get()
    a=dh_a.get()
    b=dh_b.get()

    p=int(p)
    g=int(g)
    a=int(a)
    b=int(b)

    A=mod_exp(g,a,p)
    B=mod_exp(g,b,p)

    keyA=mod_exp(B,a,p)
    keyB=mod_exp(A,b,p)

    dh_result.config(text=f"A={A} B={B}\nSharedKeyA={keyA}\nSharedKeyB={keyB}")

# ELGAMAL

def elgamal_generate():

    global elg_p,elg_g,elg_x,elg_y

    elg_p=generate_prime()
    elg_g=random.randint(2,elg_p-1)
    elg_x=random.randint(2,elg_p-2)

    elg_y=mod_exp(elg_g,elg_x,elg_p)

    elg_pub.config(text=f"Public: p={elg_p} g={elg_g} y={elg_y}")
    elg_priv.config(text=f"Private x={elg_x}")

def elgamal_encrypt():

    m=int(elg_plain.get())

    k=random.randint(2,elg_p-2)

    a=mod_exp(elg_g,k,elg_p)
    b=(m*mod_exp(elg_y,k,elg_p))%elg_p

    elg_cipher.delete(0,tk.END)
    elg_cipher.insert(0,f"{a},{b}")

def elgamal_decrypt():

    a,b=elg_cipher.get().split(",")
    a=int(a)
    b=int(b)

    s=mod_exp(a,elg_x,elg_p)
    s_inv=mod_inverse(s,elg_p)

    m=(b*s_inv)%elg_p

    elg_decrypted.delete(0,tk.END)
    elg_decrypted.insert(0,str(m))

# ECC 

def ecc_add(P,Q,a,p):

    if P=="O": return Q
    if Q=="O": return P

    x1,y1=P
    x2,y2=Q

    if x1==x2 and y1!=y2:
        return "O"

    if P!=Q:
        m=((y2-y1)*mod_inverse(x2-x1,p))%p
    else:
        m=((3*x1*x1+a)*mod_inverse(2*y1,p))%p

    x3=(m*m-x1-x2)%p
    y3=(m*(x1-x3)-y1)%p

    return (x3,y3)

def ecc_multiply(k,P,a,p):

    result="O"
    temp=P

    while k>0:

        if k%2==1:
            result=ecc_add(result,temp,a,p)

        temp=ecc_add(temp,temp,a,p)

        k//=2

    return result

