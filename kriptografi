# DSA / DSS SIMPLIFIED

def simple_hash(m):

    h=0
    for c in m:
        h+=ord(c)

    return h%1000

def dsa_sign():

    global dsa_p,dsa_q,dsa_g,dsa_x,dsa_y

    dsa_p=593
    dsa_q=29
    dsa_g=123

    dsa_x=random.randint(1,dsa_q-1)

    dsa_y=mod_exp(dsa_g,dsa_x,dsa_p)

    message=dsa_message.get()

    h=simple_hash(message)

    k=random.randint(1,dsa_q-1)

    r=mod_exp(dsa_g,k,dsa_p)%dsa_q
    k_inv=mod_inverse(k,dsa_q)

    s=(k_inv*(h+dsa_x*r))%dsa_q

    dsa_signature.config(text=f"Signature (r,s)=({r},{s})")

def dsa_verify():

    message=dsa_message.get()
    r=int(dsa_r.get())
    s=int(dsa_s.get())

    h=simple_hash(message)

    w=mod_inverse(s,dsa_q)

    u1=(h*w)%dsa_q
    u2=(r*w)%dsa_q

    v=((mod_exp(dsa_g,u1,dsa_p)*mod_exp(dsa_y,u2,dsa_p))%dsa_p)%dsa_q

    if v==r:
        dsa_verify_result.config(text="Signature VALID")
    else:
        dsa_verify_result.config(text="Signature INVALID")

